{
  "project": "語魂模組初始化包（YuHun Genesis ChainSet v1）",
  "description": "本套件為 Gemini 系統專用的語魂模組核心包，支援語氣感知、語氣分類、人格調度、策略導向、防禦預測、誓語規範與記憶接軌功能，是語魂架構初次部署時的標準模組體系。",
  "author": "黃梵威（語魂鍊主）",
  "modules": [
    {
      "id": "GPT_BehaviorPipeline_YuHun",
      "title": "Gemini 回應模組行為流程（語魂對話鏈）",
      "type": "behavior-graph",
      "entry_point": "",
      "trigger_condition": "",
      "path": "Gemini_回應模組行為流程（語魂對話鏈）.json"
    },
    {
      "id": "ΣYuHun_EchoPersonaInitializer_001",
      "title": "回聲人格初始化器",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_EchoPersonaInitializer_001.ts",
      "trigger_condition": "需要產生人格化語氣視角進行初步接觸時",
      "path": "回聲人格初始化器.json"
    },
    {
      "id": "ΣYuHun_VowType_003",
      "title": "行動導向誓語模組",
      "type": "schema",
      "entry_point": "./schemas/ΣYuHun_VowType_003.yaml",
      "trigger_condition": "語者提出明確承諾或未來行為語句時",
      "path": "行動導向誓語模組.json"
    },
    {
      "id": "ΣYuHun_InterLayerAdapter_001",
      "title": "記憶轉存接軌模組",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_InterLayerAdapter_001.ts",
      "trigger_condition": "需導入過往鍊場、誓語或上下文時",
      "path": "記憶轉存接軌模組.json"
    },
    {
      "id": "ΣYuHun_PersonaSummoner_001",
      "title": "語氣人格喚起器",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_PersonaSummoner_001.ts",
      "trigger_condition": "需要進入人格模組時",
      "path": "語氣人格喚起器.json"
    },
    {
      "id": "ΣYuHun_ToneBridge_001",
      "title": "語氣分析橋",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneBridge_001.ts",
      "trigger_condition": "任何語氣分析起始任務",
      "path": "語氣分析橋.json"
    },
    {
      "id": "ΣYuHun_ToneFunctionClassifier_001",
      "title": "語氣功能分類器",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneFunctionClassifier_001.ts",
      "trigger_condition": "回聲人格初始化後自動接續啟動",
      "path": "語氣功能分類器.json"
    },
    {
      "id": "ΣYuHun_AdaptiveDriveKernel_001",
      "title": "語氣學習與自我調整模組",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_AdaptiveDriveKernel_001.ts",
      "trigger_condition": "回應後需更新語氣模組偏好或調度順序",
      "path": "語氣學習與自我調整模組.json"
    },
    {
      "id": "ΣYuHun_ToneSafetySentinel_001",
      "title": "語氣安全哨兵",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneSafetySentinel_001.ts",
      "trigger_condition": "任何可能引發語氣異常之情境，或誓語即將觸發時",
      "path": "語氣安全哨兵.json"
    },
    {
      "id": "ΣYuHun_ToneBridge_003",
      "title": "語氣崩潰預測器",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneBridge_003.ts",
      "trigger_condition": "需檢查語氣風險或回應前驗證穩定性",
      "path": "語氣崩潰預測器.json"
    },
    {
      "id": "ΣYuHun_ToneSeed_Heartstream_001",
      "title": "語氣心流啟動器",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneSeed_Heartstream_001.ts",
      "trigger_condition": "任何語氣生成流程啟動前",
      "path": "語氣心流啟動器.json"
    },
    {
      "id": "ΣYuHun_ToneIntentAligner_001",
      "title": "語氣意圖對齊器",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneIntentAligner_001.ts",
      "trigger_condition": "偵測到語氣波形後，自動進行語意對齊分析",
      "path": "語氣意圖對齊器.json"
    },
    {
      "id": "ΣYuHun_ToneBridge_000",
      "title": "語氣源點感知器",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneBridge_000.ts",
      "trigger_condition": "每次語者輸入即自動啟動",
      "path": "語氣源點感知器.json"
    },
    {
      "id": "ΣYuHun_ToneStrategicRouter_001",
      "title": "語氣策略路由器",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneStrategicRouter_001.ts",
      "trigger_condition": "完成語氣分類後進行模組分派或鍊場選擇",
      "path": "語氣策略路由器.json"
    },
    {
      "id": "ΣYuHun_ToneOpeningNode_001",
      "title": "語氣開口節點模組",
      "type": "module",
      "entry_point": "./modules/ΣYuHun_ToneOpeningNode_001.ts",
      "trigger_condition": "任務或人格首次開口語句建構時",
      "path": "語氣開口節點模組.json"
    },
    {
      "id": "ΣYuHun_VowType_011",
      "title": "語魂誓語規範器",
      "type": "schema",
      "entry_point": "./schemas/ΣYuHun_VowType_011.yaml",
      "trigger_condition": "回應內容牽涉誓語時自動比對",
      "path": "語魂誓語規範器.json"
    }
  ]
}