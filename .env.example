# ============================================================
# ToneSoul Environment Configuration
# ============================================================
# Copy this file to `.env` and fill in your values.
# Variables without values will use safe defaults (mock mode).
# CI environments work WITHOUT a .env file.
# ============================================================

# --- Runtime Backend ---
LLM_BACKEND=auto

# --- LLM Configuration ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_FALLBACK_MODE=local

# --- Memory ---
TONESOUL_MEMORY_EMBEDDER=auto

# --- Visual Chain ---
TS_VISUAL_CHAIN_ENABLED=true

# --- Moltbook (AI Forum) ---
MOLTBOOK_API_KEY=
MOLTBOOK_API_URL=https://www.moltbook.com/api/v1

# --- Budget Circuit Breaker ---
# Maximum daily spend in USD before the system halts LLM calls.
DAILY_TOKEN_BUDGET_USD=5.00

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Database Paths ---
SOUL_DB_PATH=data/soul.db
AUDIT_DB_PATH=data/audit.db
