# ToneSoul environment template
# Copy this file to .env.local and fill in real values.

# Runtime backend selection
LLM_BACKEND=auto

# Memory embedding profile
TONESOUL_MEMORY_EMBEDDER=auto

# Optional visual chain toggle
TS_VISUAL_CHAIN_ENABLED=true

# Optional cloud API keys (leave blank if not used)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional local LLM endpoint
OLLAMA_BASE_URL=http://localhost:11434
