{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tonesoul.dev/schemas/governance/r_memory_packet_v1.schema.json",
  "title": "R-Memory Packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "generated_at",
    "backend",
    "dominance_order",
    "session_end_order",
    "trace_integrity",
    "parallel_lanes",
    "canonical_sources",
    "posture",
    "recent_traces",
    "recent_visitors",
    "active_claims",
    "recent_checkpoints",
    "recent_compactions",
    "recent_subject_snapshots",
    "operator_guidance"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "backend": {
      "type": "string",
      "enum": ["redis", "file", "unknown"]
    },
    "dominance_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_end_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "trace_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aegis_protected",
        "hash_chain_required",
        "source_of_truth"
      ],
      "properties": {
        "aegis_protected": {
          "type": "boolean"
        },
        "hash_chain_required": {
          "type": "boolean"
        },
        "source_of_truth": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "parallel_lanes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_commit_serialized",
        "perspectives_surface",
        "checkpoints_surface",
        "compaction_surface",
        "subject_snapshot_surface",
        "observer_cursor_surface",
        "field_surface"
      ],
      "properties": {
        "canonical_commit_serialized": {
          "type": "boolean"
        },
        "perspectives_surface": {
          "type": "string",
          "minLength": 1
        },
        "checkpoints_surface": {
          "type": "string",
          "minLength": 1
        },
        "compaction_surface": {
          "type": "string",
          "minLength": 1
        },
        "subject_snapshot_surface": {
          "type": "string",
          "minLength": 1
        },
        "observer_cursor_surface": {
          "type": "string",
          "minLength": 1
        },
        "field_surface": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonical_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "soul_integral",
        "session_count",
        "last_updated",
        "baseline_drift",
        "active_vows",
        "recent_tensions",
        "recent_aegis_vetoes"
      ],
      "properties": {
        "soul_integral": {
          "type": "number"
        },
        "session_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_updated": {
          "type": "string"
        },
        "baseline_drift": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "risk_posture": {
          "$ref": "#/$defs/risk_posture"
        },
        "active_vows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/vow"
          }
        },
        "recent_tensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tension"
          }
        },
        "recent_aegis_vetoes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/veto"
          }
        }
      }
    },
    "recent_traces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace"
      }
    },
    "recent_visitors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/visitor"
      }
    },
    "active_claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "recent_checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkpoint"
      }
    },
    "recent_compactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/compaction"
      }
    },
    "recent_subject_snapshots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subject_snapshot"
      }
    },
    "project_memory_summary": {
      "$ref": "#/$defs/project_memory_summary"
    },
    "operator_guidance": {
      "$ref": "#/$defs/operator_guidance"
    },
    "delta_feed": {
      "$ref": "#/$defs/delta_feed"
    }
  },
  "$defs": {
    "vow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "content", "source"],
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "tension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic", "severity"],
      "properties": {
        "topic": {
          "type": "string"
        },
        "severity": {
          "type": "number"
        },
        "timestamp": {
          "type": "string"
        },
        "resolution": {
          "type": "string"
        }
      }
    },
    "veto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "timestamp"],
      "properties": {
        "type": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "agent",
        "timestamp",
        "topics",
        "tension_count",
        "vow_count",
        "aegis_veto_count",
        "key_decision_count"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tension_count": {
          "type": "integer",
          "minimum": 0
        },
        "vow_count": {
          "type": "integer",
          "minimum": 0
        },
        "aegis_veto_count": {
          "type": "integer",
          "minimum": 0
        },
        "key_decision_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "visitor": {
      "type": "object",
      "additionalProperties": true,
      "required": ["agent", "timestamp", "source"],
      "properties": {
        "agent": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "agent",
        "summary",
        "paths",
        "source",
        "created_at",
        "expires_at"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "expires_at": {
          "type": "string"
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "agent",
        "session_id",
        "summary",
        "pending_paths",
        "next_action",
        "source",
        "updated_at"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "pending_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      }
    },
    "compaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compaction_id",
        "agent",
        "session_id",
        "summary",
        "carry_forward",
        "pending_paths",
        "evidence_refs",
        "next_action",
        "source",
        "updated_at"
      ],
      "properties": {
        "compaction_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "carry_forward": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pending_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      }
    },
    "subject_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_id",
        "agent",
        "session_id",
        "summary",
        "stable_vows",
        "durable_boundaries",
        "decision_preferences",
        "verified_routines",
        "active_threads",
        "evidence_refs",
        "refresh_signals",
        "source",
        "updated_at"
      ],
      "properties": {
        "snapshot_id": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "stable_vows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "durable_boundaries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_preferences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verified_routines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_threads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "refresh_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "subject_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "stable_vows",
        "durable_boundaries",
        "decision_preferences",
        "verified_routines",
        "active_threads"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "stable_vows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "durable_boundaries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_preferences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verified_routines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_threads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "level", "factors", "recommended_action", "inputs"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "level": {
          "type": "string",
          "enum": ["stable", "caution", "high", "critical"]
        },
        "factors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_action": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },
    "project_memory_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_topics",
        "recent_agents",
        "active_claim_count",
        "pending_paths",
        "carry_forward",
        "next_actions",
        "summary_text",
        "repo_progress"
      ],
      "properties": {
        "focus_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recent_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "pending_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "carry_forward": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subject_anchor": {
          "$ref": "#/$defs/subject_anchor"
        },
        "summary_text": {
          "type": "string",
          "minLength": 1
        },
        "repo_progress": {
          "$ref": "#/$defs/repo_progress"
        }
      }
    },
    "repo_progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "branch",
        "head",
        "staged_count",
        "modified_count",
        "untracked_count",
        "dirty_count",
        "path_preview"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "branch": {
          "type": "string"
        },
        "head": {
          "type": "string"
        },
        "staged_count": {
          "type": "integer",
          "minimum": 0
        },
        "modified_count": {
          "type": "integer",
          "minimum": 0
        },
        "untracked_count": {
          "type": "integer",
          "minimum": 0
        },
        "dirty_count": {
          "type": "integer",
          "minimum": 0
        },
        "path_preview": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "operator_guidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend_mode",
        "session_start",
        "session_end",
        "coordination_commands",
        "recommended_order",
        "current_reminders",
        "completion_rule"
      ],
      "properties": {
        "backend_mode": {
          "type": "string",
          "enum": ["redis", "file", "unknown"]
        },
        "session_start": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "session_end": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "coordination_commands": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "claim",
            "perspective",
            "checkpoint",
            "compaction",
            "subject_snapshot",
            "release"
          ],
          "properties": {
            "claim": {
              "type": "string",
              "minLength": 1
            },
            "perspective": {
              "type": "string",
              "minLength": 1
            },
            "checkpoint": {
              "type": "string",
              "minLength": 1
            },
            "compaction": {
              "type": "string",
              "minLength": 1
            },
            "subject_snapshot": {
              "type": "string",
              "minLength": 1
            },
            "release": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "recommended_order": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_reminders": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "completion_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "delta_compaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compaction_id", "agent", "summary", "updated_at"],
      "properties": {
        "compaction_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      }
    },
    "delta_subject_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "agent", "summary", "updated_at"],
      "properties": {
        "snapshot_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      }
    },
    "delta_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpoint_id", "agent", "summary", "next_action", "updated_at"],
      "properties": {
        "checkpoint_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "next_action": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      }
    },
    "delta_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "agent", "timestamp", "topics"],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "delta_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "agent", "summary"],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "repo_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changed",
        "previous_head",
        "current_head",
        "previous_dirty_count",
        "current_dirty_count"
      ],
      "properties": {
        "changed": {
          "type": "boolean"
        },
        "previous_head": {
          "type": "string"
        },
        "current_head": {
          "type": "string"
        },
        "previous_dirty_count": {
          "type": "integer",
          "minimum": 0
        },
        "current_dirty_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "delta_feed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observer_id",
        "first_observation",
        "has_updates",
        "update_count",
        "previous_seen_at",
        "summary_text",
        "new_compactions",
        "new_subject_snapshots",
        "new_checkpoints",
        "new_traces",
        "new_claims",
        "released_claim_ids",
        "repo_change",
        "ack_command"
      ],
      "properties": {
        "observer_id": {
          "type": "string"
        },
        "first_observation": {
          "type": "boolean"
        },
        "has_updates": {
          "type": "boolean"
        },
        "update_count": {
          "type": "integer",
          "minimum": 0
        },
        "previous_seen_at": {
          "type": "string"
        },
        "summary_text": {
          "type": "string"
        },
        "new_compactions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/delta_compaction"
          }
        },
        "new_subject_snapshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/delta_subject_snapshot"
          }
        },
        "new_checkpoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/delta_checkpoint"
          }
        },
        "new_traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/delta_trace"
          }
        },
        "new_claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/delta_claim"
          }
        },
        "released_claim_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repo_change": {
          "$ref": "#/$defs/repo_change"
        },
        "ack_command": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
