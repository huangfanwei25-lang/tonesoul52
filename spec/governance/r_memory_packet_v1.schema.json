{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tonesoul.dev/schemas/governance/r_memory_packet_v1.schema.json",
  "title": "R-Memory Packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "generated_at",
    "backend",
    "dominance_order",
    "session_end_order",
    "trace_integrity",
    "parallel_lanes",
    "canonical_sources",
    "posture",
    "recent_traces",
    "recent_visitors",
    "active_claims",
    "recent_checkpoints",
    "recent_compactions",
    "recent_subject_snapshots",
    "recent_routing_events",
    "coordination_mode",
    "operator_guidance"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "backend": {
      "type": "string",
      "enum": ["redis", "file", "unknown"]
    },
    "dominance_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_end_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "trace_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aegis_protected",
        "hash_chain_required",
        "source_of_truth"
      ],
      "properties": {
        "aegis_protected": {
          "type": "boolean"
        },
        "hash_chain_required": {
          "type": "boolean"
        },
        "source_of_truth": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "parallel_lanes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_commit_serialized",
        "perspectives_surface",
        "checkpoints_surface",
        "compaction_surface",
        "subject_snapshot_surface",
        "observer_cursor_surface",
        "routing_events_surface",
        "field_surface"
      ],
      "properties": {
        "canonical_commit_serialized": {
          "type": "boolean"
        },
        "perspectives_surface": {
          "type": "string",
          "minLength": 1
        },
        "checkpoints_surface": {
          "type": "string",
          "minLength": 1
        },
        "compaction_surface": {
          "type": "string",
          "minLength": 1
        },
        "subject_snapshot_surface": {
          "type": "string",
          "minLength": 1
        },
        "observer_cursor_surface": {
          "type": "string",
          "minLength": 1
        },
        "routing_events_surface": {
          "type": "string",
          "minLength": 1
        },
        "field_surface": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonical_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "soul_integral",
        "session_count",
        "last_updated",
        "baseline_drift",
        "active_vows",
        "recent_tensions",
        "recent_aegis_vetoes"
      ],
      "properties": {
        "soul_integral": {
          "type": "number"
        },
        "session_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_updated": {
          "type": "string"
        },
        "freshness_hours": {
          "type": "number",
          "minimum": 0.0
        },
        "baseline_drift": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "risk_posture": {
          "$ref": "#/$defs/risk_posture"
        },
        "active_vows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/vow"
          }
        },
        "recent_tensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tension"
          }
        },
        "recent_aegis_vetoes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/veto"
          }
        }
      }
    },
    "recent_traces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace"
      }
    },
    "recent_visitors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/visitor"
      }
    },
    "active_claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "recent_checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkpoint"
      }
    },
    "recent_compactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/compaction"
      }
    },
    "recent_subject_snapshots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subject_snapshot"
      }
    },
    "recent_routing_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/routing_event"
      }
    },
    "project_memory_summary": {
      "$ref": "#/$defs/project_memory_summary"
    },
    "coordination_mode": {
      "$ref": "#/$defs/coordination_mode"
    },
    "operator_guidance": {
      "$ref": "#/$defs/operator_guidance"
    },
    "delta_feed": {
      "$ref": "#/$defs/delta_feed"
    }
  },
  "$defs": {
    "vow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "content", "source"],
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "tension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic", "severity"],
      "properties": {
        "topic": {
          "type": "string"
        },
        "severity": {
          "type": "number"
        },
        "timestamp": {
          "type": "string"
        },
        "resolution": {
          "type": "string"
        }
      }
    },
    "veto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "timestamp"],
      "properties": {
        "type": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "agent",
        "timestamp",
        "topics",
        "tension_count",
        "vow_count",
        "aegis_veto_count",
        "key_decision_count"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "freshness_hours": {
          "type": "number",
          "minimum": 0.0
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tension_count": {
          "type": "integer",
          "minimum": 0
        },
        "vow_count": {
          "type": "integer",
          "minimum": 0
        },
        "aegis_veto_count": {
          "type": "integer",
          "minimum": 0
        },
        "key_decision_count": {
          "type": "integer",
          "minimum": 0
        },
        "council_dossier_summary": {
          "$ref": "#/$defs/council_dossier_summary"
        }
      }
    },
    "council_dossier_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_verdict",
        "confidence_posture",
        "coherence_score",
        "dissent_ratio",
        "has_minority_report"
      ],
      "properties": {
        "final_verdict": {
          "type": "string"
        },
        "confidence_posture": {
          "type": "string"
        },
        "coherence_score": {
          "type": "number"
        },
        "dissent_ratio": {
          "type": "number"
        },
        "has_minority_report": {
          "type": "boolean"
        },
        "deliberation_mode": {
          "type": "string"
        },
        "opacity_declaration": {
          "type": "string"
        },
        "evolution_suppression_flag": {
          "type": "boolean"
        },
        "confidence_decomposition": {
          "$ref": "#/$defs/confidence_decomposition"
        }
      }
    },
    "confidence_decomposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calibration_status",
        "agreement_score",
        "coverage_posture",
        "distinct_perspectives",
        "evidence_density",
        "evidence_posture",
        "grounding_posture",
        "adversarial_posture"
      ],
      "properties": {
        "calibration_status": {
          "type": "string"
        },
        "agreement_score": {
          "type": "number"
        },
        "coverage_posture": {
          "type": "string"
        },
        "distinct_perspectives": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_density": {
          "type": "number"
        },
        "evidence_posture": {
          "type": "string"
        },
        "grounding_posture": {
          "type": "string"
        },
        "adversarial_posture": {
          "type": "string"
        }
      }
    },
    "council_vote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["perspective", "decision", "confidence"],
      "properties": {
        "perspective": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        },
        "reasoning": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "council_dossier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dossier_version",
        "final_verdict",
        "confidence_posture",
        "coherence_score",
        "dissent_ratio",
        "minority_report",
        "vote_summary",
        "change_of_position",
        "evidence_refs",
        "grounding_summary"
      ],
      "properties": {
        "dossier_version": {
          "type": "string"
        },
        "final_verdict": {
          "type": "string"
        },
        "confidence_posture": {
          "type": "string"
        },
        "coherence_score": {
          "type": "number"
        },
        "dissent_ratio": {
          "type": "number"
        },
        "minority_report": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/council_vote"
          }
        },
        "vote_summary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/council_vote"
          }
        },
        "deliberation_mode": {
          "type": "string"
        },
        "change_of_position": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "grounding_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["has_ungrounded_claims", "total_evidence_sources"],
          "properties": {
            "has_ungrounded_claims": {
              "type": "boolean"
            },
            "total_evidence_sources": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "confidence_decomposition": {
          "$ref": "#/$defs/confidence_decomposition"
        },
        "opacity_declaration": {
          "type": "string"
        },
        "evolution_suppression_flag": {
          "type": "boolean"
        }
      }
    },
    "visitor": {
      "type": "object",
      "additionalProperties": true,
      "required": ["agent", "timestamp", "source"],
      "properties": {
        "agent": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "agent",
        "summary",
        "paths",
        "source",
        "created_at",
        "expires_at"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "expires_at": {
          "type": "string"
        },
        "freshness_hours": {
          "type": "number",
          "minimum": 0.0
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "agent",
        "session_id",
        "summary",
        "pending_paths",
        "next_action",
        "source",
        "updated_at"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "pending_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "freshness_hours": {
          "type": "number",
          "minimum": 0.0
        },
        "council_dossier": {
          "$ref": "#/$defs/council_dossier"
        }
      }
    },
    "compaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compaction_id",
        "agent",
        "session_id",
        "summary",
        "carry_forward",
        "pending_paths",
        "evidence_refs",
        "next_action",
        "source",
        "updated_at"
      ],
      "properties": {
        "compaction_id": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "carry_forward": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pending_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "freshness_hours": {
          "type": "number",
          "minimum": 0.0
        }
      }
    },
    "subject_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_id",
        "agent",
        "session_id",
        "summary",
        "stable_vows",
        "durable_boundaries",
        "decision_preferences",
        "verified_routines",
        "active_threads",
        "evidence_refs",
        "refresh_signals",
        "source",
        "updated_at"
      ],
      "properties": {
        "snapshot_id": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "stable_vows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "durable_boundaries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_preferences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verified_routines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_threads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "refresh_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string",
          "minLength": 1
        },
        "freshness_hours": {
          "type": "number",
          "minimum": 0.0
        }
      }
    },
    "subject_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "stable_vows",
        "durable_boundaries",
        "decision_preferences",
        "verified_routines",
        "active_threads"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "stable_vows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "durable_boundaries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_preferences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verified_routines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_threads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "level", "factors", "recommended_action", "inputs"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "level": {
          "type": "string",
          "enum": ["stable", "caution", "high", "critical"]
        },
        "factors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_action": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },
    "project_memory_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_topics",
        "recent_agents",
        "active_claim_count",
        "pending_paths",
        "carry_forward",
        "next_actions",
        "summary_text",
        "repo_progress"
      ],
      "properties": {
        "focus_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recent_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "pending_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "carry_forward": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subject_anchor": {
          "$ref": "#/$defs/subject_anchor"
        },
        "summary_text": {
          "type": "string",
          "minLength": 1
        },
        "repo_progress": {
          "$ref": "#/$defs/repo_progress"
        },
        "routing_summary": {
          "$ref": "#/$defs/routing_summary"
        },
        "subject_refresh": {
          "$ref": "#/$defs/subject_refresh"
        }
      }
    },
    "subject_refresh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "refresh_recommended",
        "snapshot_present",
        "latest_snapshot_id",
        "snapshot_updated_at",
        "risk_level",
        "newer_compaction_count",
        "newer_checkpoint_count",
        "active_claim_count",
        "routing_misroute_signal_count",
        "field_guidance",
        "promotion_hazards",
        "recommended_command",
        "summary_text"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "refresh_recommended": {
          "type": "boolean"
        },
        "snapshot_present": {
          "type": "boolean"
        },
        "latest_snapshot_id": {
          "type": "string"
        },
        "snapshot_updated_at": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "minLength": 1
        },
        "newer_compaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "newer_checkpoint_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "routing_misroute_signal_count": {
          "type": "integer",
          "minimum": 0
        },
        "field_guidance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subject_refresh_field"
          }
        },
        "promotion_hazards": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_command": {
          "type": "string"
        },
        "summary_text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "subject_refresh_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "action",
        "evidence_level",
        "candidate_values",
        "reason"
      ],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "evidence_level": {
          "type": "string",
          "minLength": 1
        },
        "candidate_values": {
          "type": "array",
