{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Fan1234-1/tonesoul52/skills/registry.schema.json",
  "title": "ToneSoul Skill Registry",
  "description": "Schema for skills/registry.json. Mirrors the contract enforced by scripts/verify_skill_registry.py: every .agent/skills/*/SKILL.md must have exactly one registry entry whose l1_routing / l2_signature fields match the skill file's YAML frontmatter, and whose integrity.sha256 is the SHA-256 of the file with line endings normalized to LF.",
  "type": "object",
  "required": ["registry_version", "max_review_age_days", "skills"],
  "properties": {
    "registry_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "max_review_age_days": {
      "type": "integer",
      "minimum": 1
    },
    "generated_by": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/skill" }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": ["id", "version", "license", "path", "l1_routing", "l2_signature", "compatibility", "trust", "integrity"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Must equal the SKILL.md frontmatter `name`. Reserved namespace terms (claude, anthropic) are rejected."
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "pattern": "^\\.agent/skills/[^/]+/SKILL\\.md$"
        },
        "l1_routing": {
          "type": "object",
          "required": ["name", "intent", "triggers"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "intent": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160,
              "description": "Must contain at least one trigger term (normalized match). No < or > characters."
            },
            "triggers": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          }
        },
        "l2_signature": {
          "type": "object",
          "required": ["execution_profile", "trust_tier", "json_schema"],
          "properties": {
            "execution_profile": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "enum": ["interactive", "engineering", "any"] }
            },
            "trust_tier": {
              "type": "string",
              "enum": ["trusted", "reviewed", "experimental"],
              "description": "Must equal trust.tier."
            },
            "json_schema": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "const": "object" }
              }
            }
          }
        },
        "compatibility": {
          "type": "object",
          "required": ["runtime", "os"],
          "properties": {
            "runtime": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "os": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        "trust": {
          "type": "object",
          "required": ["tier", "review_owner", "reviewed_at"],
          "properties": {
            "tier": {
              "type": "string",
              "enum": ["trusted", "reviewed", "experimental"]
            },
            "review_owner": { "type": "string", "minLength": 1 },
            "reviewed_at": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Must not be in the future and must be within max_review_age_days of today."
            }
          }
        },
        "integrity": {
          "type": "object",
          "required": ["sha256"],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$",
              "description": "SHA-256 of the SKILL.md bytes with CRLF/CR normalized to LF."
            }
          }
        }
      }
    }
  }
}
