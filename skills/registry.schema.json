{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToneSoul Skill Registry",
  "type": "object",
  "required": [
    "registry_version",
    "max_review_age_days",
    "skills"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "registry_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "max_review_age_days": {
      "type": "integer",
      "minimum": 1
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skill"
      }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": [
        "id",
        "path",
        "version",
        "license",
        "compatibility",
        "l1_routing",
        "l2_signature",
        "trust",
        "integrity"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "path": {
          "type": "string",
          "pattern": "^\\.agent/skills/[A-Za-z0-9_-]+/SKILL\\.md$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "compatibility": {
          "type": "object",
          "required": [
            "runtime",
            "os"
          ],
          "properties": {
            "runtime": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "os": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "l1_routing": {
          "$ref": "#/$defs/l1_routing"
        },
        "l2_signature": {
          "$ref": "#/$defs/l2_signature"
        },
        "trust": {
          "type": "object",
          "required": [
            "tier",
            "review_owner",
            "reviewed_at"
          ],
          "properties": {
            "tier": {
              "type": "string",
              "enum": [
                "trusted",
                "reviewed",
                "experimental"
              ]
            },
            "review_owner": {
              "type": "string",
              "minLength": 1
            },
            "reviewed_at": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        },
        "integrity": {
          "type": "object",
          "required": [
            "sha256"
          ],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        }
      }
    },
    "l1_routing": {
      "type": "object",
      "required": [
        "name",
        "triggers",
        "intent"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "intent": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      }
    },
    "l2_signature": {
      "type": "object",
      "required": [
        "execution_profile",
        "trust_tier",
        "json_schema"
      ],
      "properties": {
        "execution_profile": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "interactive",
              "engineering",
              "any"
            ]
          }
        },
        "trust_tier": {
          "type": "string",
          "enum": [
            "trusted",
            "reviewed",
            "experimental"
          ]
        },
        "json_schema": {
          "type": "object"
        }
      }
    }
  }
}
