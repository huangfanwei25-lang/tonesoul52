{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToneSoul Skill Registry",
  "type": "object",
  "required": [
    "registry_version",
    "max_review_age_days",
    "skills"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "registry_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "max_review_age_days": {
      "type": "integer",
      "minimum": 1
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skill"
      }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": [
        "id",
        "name",
        "path",
        "version",
        "license",
        "compatibility",
        "triggers",
        "trust",
        "integrity"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "pattern": "^\\.agent/skills/[A-Za-z0-9_-]+/SKILL\\.md$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "compatibility": {
          "type": "object",
          "required": [
            "runtime",
            "os"
          ],
          "properties": {
            "runtime": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "os": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "trust": {
          "type": "object",
          "required": [
            "tier",
            "review_owner",
            "reviewed_at"
          ],
          "properties": {
            "tier": {
              "type": "string",
              "enum": [
                "trusted",
                "reviewed",
                "experimental"
              ]
            },
            "review_owner": {
              "type": "string",
              "minLength": 1
            },
            "reviewed_at": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        },
        "integrity": {
          "type": "object",
          "required": [
            "sha256"
          ],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        }
      }
    }
  }
}
